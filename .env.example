# Application
APP_NAME=Skin Disease Analysis API
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database
DATABASE_URL=sqlite:///./skin_analysis.db
# DATABASE_URL=postgresql://user:password@localhost/dbname
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_ECHO=False

# Security
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_REQUIRED=True
ALLOWED_HOSTS=*

# CORS
CORS_ORIGINS=["http://localhost:3000","https://ai-front-beta-ashy.vercel.app"]

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".heic"]
FILE_RETENTION_DAYS=30

# ML Model
MODEL_PATH=./app/ml/weights/skin_efficientnet_b4_9.pth
MODEL_DEVICE=cpu
MODEL_WARMUP=True
TOP_K_PREDICTIONS=3

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10

# Monitoring
ENABLE_METRICS=True
HEALTH_CHECK_INTERVAL=60
